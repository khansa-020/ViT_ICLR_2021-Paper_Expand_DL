        "        out = model.vit(pixel_values=images)\n",
        "        cls_tokens = out.last_hidden_state[:, 0, :].cpu().numpy()  # CLS token\n",
        "        all_feats.append(cls_tokens)\n",
        "        all_lbls.extend(labels.squeeze().numpy())\n",
        "\n",
        "all_feats = np.vstack(all_feats)\n",
